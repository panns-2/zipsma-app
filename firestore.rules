
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global & Helper Functions ---

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    function isSchoolAdmin(schoolId) {
      return isSuperAdmin() || 
             (request.auth != null && schoolId != null && 
              ((exists(/databases/$(database)/documents/schools/$(schoolId)) && get(/databases/$(database)/documents/schools/$(schoolId)).data.adminUid == request.auth.uid) ||
               (exists(/databases/$(database)/documents/schools/$(schoolId.upper())) && get(/databases/$(database)/documents/schools/$(schoolId.upper())).data.adminUid == request.auth.uid) ||
               (exists(/databases/$(database)/documents/schools/$(schoolId.lower())) && get(/databases/$(database)/documents/schools/$(schoolId.lower())).data.adminUid == request.auth.uid)));
    }

    function isSuperAdmin() {
        return request.auth != null && 
               (request.auth.uid == 'KpzZ3S5XFRPAeNiB9PneLK1Y1aB3' || 
                request.auth.token.email == 'solandy242@gmail.com');
    }

    function isStaffAdmin(schoolId) {
      return request.auth != null && schoolId != null && 
             (
              (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && 
               (get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.schoolId.upper() == schoolId.upper()) &&
               (get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'Administrator' || 
                get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'Principal' ||
                get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'Accountant'))
              || isSchoolAdmin(schoolId)
             );
    }

    // --- Global Application Settings ---

    match /settings/{settingId} {
      allow read, write: if isSuperAdmin();
    }

    // --- School Registration & Login ---

    match /schools/{schoolId} {
      allow create: if request.auth != null && request.resource.data.adminUid == request.auth.uid;
      allow get: if true;
      allow list: if isSuperAdmin() || (request.auth != null && resource.data.adminUid == request.auth.uid);
      allow update: if isSchoolAdmin(schoolId);

      // School-specific settings (e.g. feeReminders)
      match /settings/{settingId} {
        allow read, write: if isSchoolAdmin(schoolId);
      }
    }

    // --- Public Get Rules for Login ---
    
    match /staff/{staffId} {
      allow get: if true;
    }

    // --- Public Read Rules for Student/Parent Dashboard ---
    match /homework/{homeworkId} {
      allow read: if true;
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isSchoolAdmin(request.resource.data.schoolId) || isSchoolAdmin(resource.data.schoolId);
      allow delete: if isSchoolAdmin(resource.data.schoolId);
    }
    match /schoolCalendar/{eventId} {
        allow read: if true;
        allow create: if isSchoolAdmin(request.resource.data.schoolId);
        allow update: if isSchoolAdmin(request.resource.data.schoolId) || isSchoolAdmin(resource.data.schoolId);
        allow delete: if isSchoolAdmin(resource.data.schoolId);
    }
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isSchoolAdmin(request.resource.data.schoolId) || isSchoolAdmin(resource.data.schoolId);
      allow delete: if isSchoolAdmin(resource.data.schoolId);
    }
    
    // --- Rules for Students ---
    match /students/{studentId} {
        // Admins can create, read, and delete students.
        allow create: if isSchoolAdmin(request.resource.data.get('schoolId', null));
        allow read, delete: if isSchoolAdmin(resource.data.get('schoolId', null));
        
        // Anyone can get a student doc or list students (for dashboards)
        allow get, list: if true;

        // Updates are allowed if:
        // 1. The user is a super admin or school admin for the current/new school ID.
        // 2. The user is a staff member with administrative role.
        // 3. OR the update is restricted to ONLY the 'attendance' field.
        allow update: if isSuperAdmin() || 
                         isSchoolAdmin(resource.data.get('schoolId', null)) || 
                         isSchoolAdmin(request.resource.data.get('schoolId', null)) ||
                         isStaffAdmin(resource.data.get('schoolId', null)) ||
                         isStaffAdmin(request.resource.data.get('schoolId', null)) ||
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendance', 'ledger', 'schoolId']);
    }

    // --- Staff, Finances, and Admin Data ---
    
    match /staff/{docId} {
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow read, update, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /staffDetails/{docId} {
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow read, update, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /expenditure/{docId} {
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow read, update, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /debts/{docId} {
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow read, update, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /reportSettings/{schoolId} {
        allow read: if true; // Publicly readable for dashboards
        allow write: if isSchoolAdmin(schoolId);
    }

    match /studentReports/{reportId} {
        allow read: if true; // Publicly readable for parents/students
        allow create: if isSchoolAdmin(request.resource.data.schoolId);
        allow update, delete: if isSchoolAdmin(resource.data.schoolId);
        allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /academicPeriods/{periodId} {
      allow read: if true;
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow update, delete: if isSchoolAdmin(resource.data.schoolId);
    }

    match /feeCategories/{categoryId} {
      allow read: if true;
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow update, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if true;
    }

    match /dailyFeeCategories/{categoryId} {
      allow create: if isSchoolAdmin(request.resource.data.schoolId);
      allow update: if isSchoolAdmin(request.resource.data.schoolId);
      allow read, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }

    match /cron_logs/{logId} {
      allow read, list: if (resource.data.schoolId == 'global' && request.auth != null) || isSchoolAdmin(resource.data.schoolId);
    }

    match /pending_payments/{docId} {
      allow read, delete: if isSchoolAdmin(resource.data.schoolId);
      allow list: if isSchoolAdmin(resource.data.schoolId);
    }
  }
}
